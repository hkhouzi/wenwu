# HeritageDoc Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# JWT - 请在生产环境替换为随机字符串
JWT_SECRET=heritagedoc-jwt-secret-2026-change-this-in-production

# Database - PostgreSQL (for cloud deployment)
# 开发环境保留 sqlite，云端部署改为 postgresql
DB_TYPE=sqlite
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=heritagedoc
POSTGRES_USER=heritagedoc
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_SSL=false

# Email Service - QQ 邮箱 SMTP 配置
# QQ 邮箱需要开启 SMTP 服务并获取授权码（不是 QQ 密码！）
# 获取方式：QQ邮箱网页版 → 设置 → 账户 → 开启 POP3/SMTP → 发送短信生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-qq-number@qq.com
SMTP_PASS=your-qq-authorization-code
SMTP_FROM="HeritageDoc <noreply@heritagedoc.com>"

# 备选：Resend 邮件服务（推荐，无需配置 SMTP）
# 申请地址：https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=HeritageDoc <onboarding@resend.dev>

# Cloud Storage（Phase 2 才会用到）
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key
# OSS_ACCESS_KEY_SECRET=your-secret-key
# OSS_BUCKET=heritagedoc-uploads
